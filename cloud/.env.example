# 云端部署时复制为项目根目录 .env，并替换为真实值；此文件不能填写真实密钥
ELEME_ISV_COOKIE=
# 可选：浏览器导出的 Cookie JSON，配置后优先于 ELEME_ISV_COOKIE
COOKIE_BUNDLE_PATH=
VECTORENGINE_API_KEY=
VECTORENGINE_BASE_URL=https://api.vectorengine.ai
VECTORENGINE_MODEL=gpt-5.6-luna
APP_PORT=8792
CHROME_DEBUG_PORT=9222
CHROME_PROFILE=/home/devbox/taobao-shangou-chrome-profile
REPORT_API_TIMEOUT_MS=300000
REPORT_API_RETRIES=2
REPORT_API_RETRY_DELAY_MS=3000
REPORT_BROWSER_TIMEOUT_MS=30000
REPORT_LLM_CONCURRENCY=3
